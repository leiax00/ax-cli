#!/bin/bash
# ax - 自定义命令管理器
# 安装: ln -sf ~/.dotfiles/bin/ax ~/.local/bin/ax

AX_FILE="$HOME/.ax-commands.json"
DOTDIR="$HOME/.dotfiles"
AX_REPO_FILE="$DOTDIR/ax-commands.json"
AUTO_SYNC=true  # 设为 false 关闭自动同步

_init() {
  # 优先从 dotfiles 仓库加载，不存在则创建空文件
  if [ ! -f "$AX_FILE" ] && [ -f "$AX_REPO_FILE" ]; then
    ln -sf "$AX_REPO_FILE" "$AX_FILE"
  elif [ ! -f "$AX_FILE" ]; then
    echo '{}' > "$AX_FILE"
  fi
}

_sync() {
  [ "$AUTO_SYNC" != "true" ] && return
  [ ! -d "$DOTDIR/.git" ] && return
  # 如果是符号链接，不需要复制
  [ -L "$AX_FILE" ] && return
  cp "$AX_FILE" "$AX_REPO_FILE" 2>/dev/null || return
  cd "$DOTDIR"
  git add ax-commands.json
  if git diff --cached --quiet; then
    return
  fi
  local msg="sync: $1 ax command '$2'"
  git commit -m "$msg" --quiet
  git push --quiet 2>/dev/null &
  echo "☁️  已同步到远程仓库"
}

_add() {
  local name="$1" cmd="$2" desc="$3"
  _init
  local tmp=$(mktemp)
  jq --arg n "$name" --arg c "$cmd" --arg d "$desc" \
    '. + {($n): {cmd: $c, desc: $d}}' "$AX_FILE" > "$tmp" && mv "$tmp" "$AX_FILE"
  echo "✅ 已添加: $name - $desc"
  _sync "add" "$name"
}

_edit() {
  local name="$1"
  _init
  local has=$(jq -r --arg n "$name" 'has($n)' "$AX_FILE")
  if [ "$has" = "false" ]; then
    echo "❌ 未找到: $name"
    return 1
  fi
  local current_cmd=$(jq -r --arg n "$name" '.[$n].cmd' "$AX_FILE")
  local current_desc=$(jq -r --arg n "$name" '.[$n].desc // ""' "$AX_FILE")
  echo "当前命令: $current_cmd"
  echo "当前描述: $current_desc"
  read -rp "新命令 (直接回车保持不变): " new_cmd
  read -rp "新描述 (直接回车保持不变): " new_desc
  new_cmd="${new_cmd:-$current_cmd}"
  new_desc="${new_desc:-$current_desc}"
  local tmp=$(mktemp)
  jq --arg n "$name" --arg c "$new_cmd" --arg d "$new_desc" \
    '.[$n] = {cmd: $c, desc: $d}' "$AX_FILE" > "$tmp" && mv "$tmp" "$AX_FILE"
  echo "✅ 已更新: $name"
  _sync "edit" "$name"
}

_list() {
  _init
  echo "📋 自定义命令列表："
  echo "──────────────────────────────────────────"
  jq -r 'to_entries[] | "  \(.key)\t\(.value.desc // "无描述")\t→ \(.value.cmd)"' "$AX_FILE" \
    | column -t -s $'\t'
  echo "──────────────────────────────────────────"
}

_run() {
  _init
  local name="$1"
  if [ -n "$name" ]; then
    local cmd=$(jq -r --arg n "$name" '.[$n].cmd // empty' "$AX_FILE")
    [ -n "$cmd" ] && { echo "▶ $cmd"; eval "$cmd"; } || echo "❌ 未找到: $name"
  else
    local entry=$(jq -r 'to_entries[] | "\(.key)\t\(.value.desc // "")\t\(.value.cmd)"' "$AX_FILE" \
      | fzf --prompt="ax> " --preview='echo {3}' --bind 'enter:abort' \
      --with-nth=1,2 --delimiter=$'\t' 2>/dev/null)
    [ -n "$entry" ] && { local cmd=$(echo "$entry" | cut -f3); echo "▶ $cmd"; eval "$cmd"; }
  fi
}

_rm() {
  local name="$1"
  _init
  local has=$(jq -r --arg n "$name" 'has($n)' "$AX_FILE")
  if [ "$has" = "false" ]; then
    echo "❌ 未找到: $name"
    return 1
  fi
  local tmp=$(mktemp)
  jq --arg n "$name" 'del(.[$n])' "$AX_FILE" > "$tmp" && mv "$tmp" "$AX_FILE"
  echo "🗑️  已删除: $name"
  _sync "delete" "$name"
}

_update() {
  [ ! -d "$DOTDIR/.git" ] && echo "❌ 未找到 dotfiles 仓库: $DOTDIR" && return 1

  echo "🔄 更新 ax-system-basic..."
  echo ""

  # 1. 拉取最新配置
  echo "📦 拉取 dotfiles 仓库..."
  cd "$DOTDIR"
  local old=$(git rev-parse HEAD)
  git pull --quiet 2>&1
  local new=$(git rev-parse HEAD)
  if [ "$old" = "$new" ]; then
    echo "  ⏭️  配置已是最新"
  else
    echo "  ✅ 配置已更新: $(git log --oneline $old..$new | head -3)"
  fi

  # 2. 更新 ax 工具链接
  mkdir -p "$HOME/.local/bin"
  chmod +x "$DOTDIR/bin/"*
  for tool in "$DOTDIR/bin/"*; do
    ln -sf "$tool" "$HOME/.local/bin/$(basename "$tool")"
  done

  # 3. 检查系统包
  echo ""
  echo "📦 检查系统包..."
  if [ -f "$DOTDIR/apt-packages.txt" ]; then
    local new_pkgs=()
    while IFS= read -r pkg; do
      [ -z "$pkg" ] && continue
      dpkg -s "$pkg" &>/dev/null || new_pkgs+=("$pkg")
    done < "$DOTDIR/apt-packages.txt"
    if [ ${#new_pkgs[@]} -gt 0 ]; then
      echo "  📥 新增包: ${new_pkgs[*]}"
      sudo apt update -qq && sudo apt install -y -qq "${new_pkgs[@]}"
      echo "  ✅ 安装完成"
    else
      echo "  ⏭️  系统包齐全"
    fi
  fi

  # 4. 检查 zsh 插件
  echo ""
  echo "🔌 检查 zsh 插件..."
  local ZSH_PLUGIN_DIR="$HOME/.zsh/plugins"
  mkdir -p "$ZSH_PLUGIN_DIR"

  _check_plugin() {
    local name="$1" url="$2"
    if [ -d "$ZSH_PLUGIN_DIR/$name" ]; then
      cd "$ZSH_PLUGIN_DIR/$name" && git pull --quiet 2>&1 && echo "  ✅ $name 已更新"
    else
      git clone --depth 1 "$url" "$ZSH_PLUGIN_DIR/$name" 2>&1 && echo "  ✅ $name 已安装"
    fi
  }

  _check_plugin "zsh-autosuggestions" "https://github.com/zsh-users/zsh-autosuggestions"
  _check_plugin "zsh-syntax-highlighting" "https://github.com/zsh-users/zsh-syntax-highlighting"
  _check_plugin "zsh-completions" "https://github.com/zsh-users/zsh-completions"

  # 5. 检查字体
  echo ""
  echo "🔤 检查字体..."
  if ! fc-list | grep -q "JetBrains Mono"; then
    local FONT_DIR="$HOME/.local/share/fonts"
    mkdir -p "$FONT_DIR"
    local tmp_zip=$(mktemp)
    curl -fLo "$tmp_zip" https://github.com/ryanoasis/nerd-fonts/releases/download/v3.1.1/JetBrainsMono.zip
    unzip -qo "$tmp_zip" -d "$FONT_DIR"
    rm "$tmp_zip"
    fc-cache -fv 2>/dev/null
    echo "  ✅ 字体已安装"
  else
    echo "  ⏭️  字体已存在"
  fi

  echo ""
  echo "✅ 更新完成！运行 exec zsh 或重启终端使配置生效。"
}

case "${1:-}" in
  add)    _add "$2" "$3" "${4:-}" ;;
  edit)   _edit "$2" ;;
  update) _update ;;
  list|ls) _list ;;
  rm|del) _rm "$2" ;;
  help|--help|-h)
    echo "ax - 自定义命令管理器"
    echo ""
    echo "  ax add <名称> <命令> [描述]    添加命令"
    echo "  ax edit <名称>                  编辑命令"
    echo "  ax update                      更新整个开发环境"
    echo "  ax list                        列出所有命令"
    echo "  ax rm <名称>                   删除命令"
    echo "  ax <名称>                      执行命令"
    echo "  ax                             交互选择执行"
    echo ""
    echo "  添加/编辑/删除后自动同步到 dotfiles 仓库"
    ;;
  *) _run "$1" ;;
esac
